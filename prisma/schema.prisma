// This is your Prisma schema file
// Learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider   = "prisma-client-js"
}







datasource db {
  provider = "sqlite"
}

// ---------------------------------------------------------
// User & Profile
// ---------------------------------------------------------

model Profile {
  id                 String    @id @default(uuid()) // Maps to Supabase Auth UUID
  email              String    @unique
  firstName          String?
  lastName           String?
  role               Role      @default(USER)
  subscriptionStatus SubStatus @default(INACTIVE)
  stripeCustomerId   String?   @unique
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  scores           Score[]
  drawParticipations DrawParticipant[]
  winnings         Winner[]

  // Charity mapping
  selectedCharityId  String?
  selectedCharity    Charity?  @relation(fields: [selectedCharityId], references: [id])
  charityPercentage  Float     @default(10.0) // Users can increase > 10
}

enum Role {
  USER
  ADMIN
}

enum SubStatus {
  INACTIVE
  ACTIVE
  PAST_DUE
  CANCELED
}

// ---------------------------------------------------------
// Scores (Rolling 5)
// ---------------------------------------------------------

model Score {
  id        String   @id @default(uuid())
  profileId String
  profile   Profile  @relation(fields: [profileId], references: [id], onDelete: Cascade)
  value     Int      // 1-45 Stableford
  datePlayed DateTime 
  createdAt DateTime @default(now())

  @@index([profileId, createdAt(sort: Desc)])
}

// ---------------------------------------------------------
// Charities
// ---------------------------------------------------------

model Charity {
  id          String   @id @default(uuid())
  name        String
  description String
  category    String   @default("General")
  location    String   @default("Global")
  imageUrl    String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  
  supporters  Profile[]
}

// ---------------------------------------------------------
// Draw System & Winning Ledger
// ---------------------------------------------------------

model DrawResult {
  id            String   @id @default(uuid())
  monthYear     String   @unique // e.g. "2026-03"
  poolTotal     Float    
  winningNumbers String   // "12,34,5,22,41"
  status        DrawState @default(DRAFT)
  createdAt     DateTime @default(now())
  executedAt    DateTime?

  winners       Winner[]
  participants  DrawParticipant[]
}

enum DrawState {
  DRAFT       // Simulation
  PUBLISHED   // Official
}

model DrawParticipant {
  id           String     @id @default(uuid())
  drawId       String
  draw         DrawResult @relation(fields: [drawId], references: [id], onDelete: Cascade)
  profileId    String
  profile      Profile    @relation(fields: [profileId], references: [id], onDelete: Cascade)
  lockedScores String      // comma-separated snapshot
}

model Winner {
  id            String     @id @default(uuid())
  drawId        String
  draw          DrawResult @relation(fields: [drawId], references: [id], onDelete: Cascade)
  profileId     String
  profile       Profile    @relation(fields: [profileId], references: [id], onDelete: Cascade)
  
  matchCount    Int        // 3, 4, or 5
  prizeAmount   Float
  proofImageUrl String?    // Uploaded verification screenshot
  status        PayoutStatus @default(PENDING_PROOF)
}

enum PayoutStatus {
  PENDING_PROOF
  PENDING_ADMIN_REVIEW
  APPROVED_PENDING_PAYMENT
  PAID
  REJECTED
}
